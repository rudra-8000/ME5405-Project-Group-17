## 4.5 Classify Characters in Image 2
```matlab
function classified_labels = classify_image2_characters(char_images, trained_model, classifier_type)
    % Classify each character in Image 2
    
    num_chars = length(char_images);
    classified_labels = cell(num_chars, 1);
    class_names = {'1', '2', '3', 'A', 'B', 'C'};
    
    for i = 1:num_chars
        % Extract features
        features = extract_features(char_images{i});
        
        % Classify based on classifier type
        if strcmp(classifier_type, 'knn')
            label_idx = knn_classify(trained_model.train_features, ...
                                     trained_model.train_labels, ...
                                     features, trained_model.k);
        elseif strcmp(classifier_type, 'svm')
            % label_idx = svm_classify(trained_model, features);
            label_idx = 1;  % Placeholder
        else
            error('Unknown classifier type');
        end
        
        classified_labels{i} = class_names{label_idx};
    end
end

